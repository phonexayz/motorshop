@model IEnumerable<MotorcycleRepairShop.Models.Customer>
@{
    ViewData["Title"] = "ຈັດການຂໍ້ມູນລູກຄ້າ";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="bi bi-people"></i> ຈັດການຖານຂໍ້ມູນລູກຄ້າ</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-person-plus"></i> ເເພີ່ມລູກຄ້າໃໝ່
        </a>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-10">
                <input type="text" name="search" class="form-control" placeholder="ຄົ້ນຫາດ້ວຍ ຊື່, ເບີໂທ, ຫຼື ທະບຽນລົດ..." value="@ViewBag.Search">
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-primary w-100">ຄົ້ນຫາ</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">ຊື່ລູກຄ້າ</th>
                        <th>ເບີຕິດຕໍ່</th>
                        <th>ທະບຽນລົດ</th>
                        <th>ຂໍ້ມູນລົດຈັກ</th>
                        <th>ວັນທີລົງທະບຽນ</th>
                        <th class="text-end pe-4">ຈັດການ</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">@item.Name</td>
                                <td>@(string.IsNullOrEmpty(item.Phone) ? "-" : item.Phone)</td>
                                <td><span class="badge bg-secondary">@item.LicensePlate</span></td>
                                <td>@item.MotorcycleBrand @item.MotorcycleModel @(item.Year.HasValue ? $"({item.Year})" : "")</td>
                                <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info" title="ເບິ່ງປະຫວັດ">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning" title="ແກ້ໄຂ">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('ທ່ານແນ່ໃຈຫລືບໍ່ທີ່ຈະລຶບລູກຄ້ານີ້? (ຂໍ້ມູນໃບສັ່ງສ້ອມອາດໄດ້ຮັບຜົນກະທົບ)');">
                                            <button type="submit" class="btn btn-outline-danger" title="ລຶບ">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-people fa-3x mb-3 d-block" style="font-size: 2.5rem;"></i>
                                ບໍ່ພົບຂໍ້ມູນລູກຄ້າໃນລະບົບ
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
