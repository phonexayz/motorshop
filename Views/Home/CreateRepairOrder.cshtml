@model MotorcycleRepairShop.Models.RepairOrder

<div class="container mt-5">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0"><i class="bi bi-tools"></i> ບັນທຶກໃບສັ່ງສ້ອມໃໝ່</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">ຊື່ລູກຄ້າ</label>
                        <input type="text" name="CustomerName" class="form-control" placeholder="ລະບຸ ຊື່-ນາມສະກຸນ" required>
                    </div>
                    
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">ລຸ້ນລົດຈັກ</label>
                        <input type="text" name="MotorcycleModel" class="form-control" placeholder="ຕົວຢ່າງ: Honda Wave 110i" required>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">ວັນທີ່ເຂົ້າຮັບບໍລິການ</label>
                        <input type="date" name="ServiceDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">ສະຖານະເລີ່ມຕົ້ນ</label>
                        <select asp-for="Status" class="form-select">
                            <option value="Pending">ລໍຖ້າຄິວສ້ອມ</option>
                            <option value="InProgress">ກຳລັງສ້ອມ</option>
                            <option value="Completed">ສ້ອມສຳເລັດແລ້ວ</option>
                        </select>
                    </div>

                    <div class="col-12 mb-3">
                        <label class="form-label fw-bold">ອາການເສຍ / ລາຍການທີ່ຕ້ອງເຮັດ</label>
                        <textarea class="form-control" rows="3" placeholder="ລະບຸລາຍລະອຽດອາການ..."></textarea>
                    </div>
                </div>

                <hr />
                
                <div class="d-flex justify-content-end">
                    <button type="reset" class="btn btn-secondary me-2">ລ້າງຂໍ້ມູນ</button>
                    <button type="submit" class="btn btn-success px-4">ບັນທຶກຂໍ້ມູນ</button>
                </div>
            </form>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">