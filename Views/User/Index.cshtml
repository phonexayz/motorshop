@model IEnumerable<MotorcycleRepairShop.Models.User>
@{
    ViewData["Title"] = "ຈັດການຜູ້ໃຊ້";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<div class="main-wrapper py-4">
    <div class="container">
        
        <div class="d-flex justify-content-between align-items-end mb-4 fade-in">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item text-muted">ລະບົບບໍລິຫານຈັດການ</li>
                        <li class="breadcrumb-item active">ຜູ້ໃຊ້</li>
                    </ol>
                </nav>
                <h2 class="fw-bold mb-0 text-dark">
                    <i class="bi bi-people-fill text-primary me-2"></i>ຈັດການບັນຊີຜູ້ໃຊ້ລະບົບ
                </h2>
            </div>
            <a asp-action="Create" class="btn btn-modern-primary shadow-sm">
                <i class="bi bi-person-plus-fill me-2"></i> ເພີ່ມຜູ້ໃຊ້ໃໝ່
            </a>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-custom-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card main-card border-0 shadow-xl overflow-hidden fade-in-up">
            <div class="card-header-gradient"></div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 custom-table">
                        <thead>
                            <tr>
                                <th class="ps-4 py-4 text-uppercase small fw-bold text-muted">ຂໍ້ມູນຜູ້ໃຊ້</th>
                                <th class="py-4 text-uppercase small fw-bold text-muted">ລະດັບສິດ</th>
                                <th class="py-4 text-uppercase small fw-bold text-muted text-center">ຄວາມປອດໄພ</th>
                                <th class="py-4 text-uppercase small fw-bold text-muted text-end pe-4">ຈັດການ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-circle me-3">
                                                    @item.Username.Substring(0, 1).ToUpper()
                                                </div>
                                                <div>
                                                    <div class="fw-bold text-dark">@item.Username</div>
                                                    <small class="text-muted">ID: #@item.Id.ToString().PadLeft(4, '0')</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            @if (item.Role == "Admin")
                                            {
                                                <span class="badge-modern badge-admin">
                                                    <i class="bi bi-shield-lock-fill me-1"></i> ຜູ້ດູແລລະບົບ
                                                </span>
                                            }
                                            else if (item.Role == "Owner")
                                            {
                                                <span class="badge-modern badge-admin" style="background:#fee2e2;color:#b91c1c;">
                                                    <i class="bi bi-house-door-fill me-1"></i> ເຈົ້າຂອງຮ້ານ
                                                </span>
                                            }
                                            else if (item.Role == "Director")
                                            {
                                                <span class="badge-modern" style="background:#e0e7ff;color:#4338ca;">
                                                    <i class="bi bi-building me-1"></i> ຜູ້ອຳນວຍການ
                                                </span>
                                            }
                                            else if (item.Role == "Manager")
                                            {
                                                <span class="badge-modern badge-manager">
                                                    <i class="bi bi-briefcase-fill me-1"></i> ຜູ້ຈັດການ
                                                </span>
                                            }
                                            else if (item.Role == "Mechanic")
                                            {
                                                <span class="badge-modern badge-staff">
                                                    <i class="bi bi-wrench-adjustable me-1"></i> ຊ່າງສ້ອມ
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge-modern badge-staff" style="background:#f1f5f9;color:#475569;">
                                                    <i class="bi bi-person-badge-fill me-1"></i> ພະນັກງານ
                                                </span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <div class="security-status shadow-none">
                                                <i class="bi bi-patch-check-fill text-success me-1"></i>
                                                <span class="small text-secondary">SHA-256 Active</span>
                                            </div>
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="d-flex justify-content-end gap-2">
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-action-edit" title="ແກ້ໄຂ">
                                                    <i class="bi bi-pencil-square"></i>
                                                </a>
                                                
                                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" 
                                                      onsubmit="return confirm('ຢືນຢັນການລຶບຜູ້ໃຊ້ @item.Username?');">
                                                    <button type="submit" class="btn btn-action-delete" 
                                                            @((Model?.Count(m => m.Role == "Admin") ?? 0) <= 1 && item.Role == "Admin" ? "disabled" : "")>
                                                        <i class="bi bi-trash3-fill"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-5">
                                        <div class="py-4">
                                            <i class="bi bi-folder2-open display-1 text-light"></i>
                                            <p class="mt-3 text-muted">ບໍ່ພົບຂໍ້ມູນຜູ້ໃຊ້ໃນລະບົບ</p>
                                            <a asp-action="Create" class="btn btn-sm btn-outline-primary rounded-pill px-4">ສ້າງຕອນນີ້</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <div class="text-center mt-4">
            <p class="text-muted small">ສະແດງທັງໝົດ @(Model?.Count() ?? 0) ບັນຊີ</p>
        </div>
    </div>
</div>
