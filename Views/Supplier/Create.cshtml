@model MotorcycleRepairShop.Models.Supplier
@{
    ViewData["Title"] = "ເພີ່ມຜູ້ສະໜອງໃໝ່";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">ເພີ່ມຜູ້ສະໜອງໃໝ່</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Index" class="btn btn-secondary shadow-sm">
            <i class="fas fa-arrow-left"></i> ກັບຄືນ
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-plus-circle"></i> ຟອມປ້ອນຂໍ້ມູນຜູ້ສະໜອງ</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label fw-bold">ຊື່ຮ້ານ / ຜູ້ສະໜອງ <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="ຕົວຢ່າງ: ຮ້ານຂາຍສົ່ງອາໄຫຼ່ ວຽງຈັນ" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ContactPerson" class="form-label fw-bold">ຜູ້ຕິດຕໍ່</label>
                            <input asp-for="ContactPerson" class="form-control" placeholder="ຊື່ຜູ້ທີ່ເຮົາຕິດຕໍ່ນຳ" />
                            <span asp-validation-for="ContactPerson" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Phone" class="form-label fw-bold">ເບີໂທລະສັບ</label>
                            <input asp-for="Phone" class="form-control" placeholder="020 xxxxxxxx" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label fw-bold">ອີເມວ</label>
                            <input asp-for="Email" class="form-control" placeholder="example@gmail.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label fw-bold">ທີ່ຢູ່</label>
                        <textarea asp-for="Address" class="form-control" rows="2" placeholder="ບ້ານ, ເມືອງ, ແຂວງ..."></textarea>
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Note" class="form-label fw-bold">ໝາຍເຫດ</label>
                        <textarea asp-for="Note" class="form-control" rows="2" placeholder="ຂໍ້ມູນເພີ່ມເຕີມ..."></textarea>
                        <span asp-validation-for="Note" class="text-danger small"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg shadow">
                            <i class="fas fa-save"></i> ບັນທຶກຂໍ້ມູນ
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
