@model IEnumerable<MotorcycleRepairShop.Models.Expense>

@{
    ViewData["Title"] = "ຈັດການລາຍຈ່າຍ";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="bi bi-wallet2 text-danger"></i> ຈັດການລາຍຈ່າຍຮ້ານ</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Create" class="btn btn-danger">
            <i class="bi bi-plus-circle"></i> ບັນທຶກລາຍຈ່າຍໃໝ່
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">ວັນທີ</th>
                        <th>ລາຍການ</th>
                        <th>ໝວດໝູ່</th>
                        <th class="text-end">ຈຳນວນເງິນ</th>
                        <th class="text-end pe-4">ຈັດການ</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted small">@item.Date.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <div class="fw-bold">@item.Title</div>
                                    @if (!string.IsNullOrEmpty(item.Notes))
                                    {
                                        <div class="text-muted small">@item.Notes</div>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-secondary-subtle text-secondary rounded-pill px-3">@item.Category</span>
                                </td>
                                <td class="text-end fw-bold text-danger">@item.Amount.ToString("N0") ₭</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning" title="ແກ້ໄຂ">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="ລຶບ">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">ຍັງບໍ່ມີຂໍ້ມູນລາຍຈ່າຍ</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
