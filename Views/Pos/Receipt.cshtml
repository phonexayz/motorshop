@model MotorcycleRepairShop.Models.RepairOrder
@inject MotorcycleRepairShop.Services.ISettingService SettingService
@{
    Layout = null;
    var shopName = await SettingService.GetValueAsync("ShopName", "ຮ້ານຊ້ອມມໍເຕີໄຊ (MotorShop)");
    var shopAddress = await SettingService.GetValueAsync("ShopAddress", "123 ຖ.ສຸຂຸມວິທ, ເມືອງວຽງຈັນ");
    var shopPhone = await SettingService.GetValueAsync("ShopPhone", "081-234-5678");
    var shopLogo = await SettingService.GetValueAsync("ShopLogo", "");
    var receiptFooter = await SettingService.GetValueAsync("ReceiptFooter", "-- ຂໍຂອບໃຈທີ່ໃຊ້ບໍລິການ --");
}

<!DOCTYPE html>
<html lang="lo">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ບິນຮັບເງິນ - @Model.OrderNumber</title>
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+Lao:wght@400;700&display=swap');
        
        body {
            font-family: 'Noto Sans Lao', sans-serif;
            font-size: 11px;
            line-height: 1.3;
            width: 74mm; /* Adjusted for better 80mm compatibility */
            margin: 0 auto;
            padding: 5px;
            color: #000;
        }
        .text-center { text-align: center; }
        .text-end { text-align: right; }
        .fw-bold { font-weight: bold; }
        .divider { border-top: 1px dashed #000; margin: 8px 0; }
        .divider-double { border-top: 2px solid #000; border-bottom: 2px solid #000; height: 3px; margin: 8px 0; }
        
        .store-header { margin-bottom: 10px; }
        .store-name { font-size: 16px; font-weight: 700; margin-bottom: 2px; text-transform: uppercase; }
        .store-info { font-size: 10px; color: #333; }
        
        .order-meta { font-size: 10px; margin-bottom: 10px; }
        
        table { width: 100%; border-collapse: collapse; margin-bottom: 10px; }
        .items-header { border-bottom: 1px solid #000; font-weight: bold; }
        .items-table td { padding: 4px 0; vertical-align: top; }
        .item-details { padding-right: 5px; }
        .item-price { white-space: nowrap; }
        
        .summary-row td { padding: 1px 0; }
        .total-row { font-size: 15px; font-weight: 700; border-top: 1px solid #000; border-bottom: 1px solid #000; }
        .total-row td { padding: 5px 0; }
        
        .footer { margin-top: 15px; font-size: 10px; }
        
        .no-print {
            padding: 15px;
            background: #f4f4f4;
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 20px;
        }
        
        @@media print {
            .no-print { display: none !important; }
            body { width: 100%; margin: 0; padding: 0; }
            @@page { margin: 0; }
        }
    </style>
</head>
<body>
    <div class="no-print">
        <button onclick="window.print()" style="cursor:pointer; padding: 8px 16px; background: #007bff; color: white; border: none; border-radius: 4px; font-weight: bold;">
            🖨️ ພິມບິນ (Print)
        </button>
        <button onclick="window.close()" style="cursor:pointer; padding: 8px 16px; background: #6c757d; color: white; border: none; border-radius: 4px;">
            ✖️ ປິດ (Close)
        </button>
    </div>

    <div class="store-header text-center">
        @if (!string.IsNullOrEmpty(shopLogo))
        {
            <img src="@shopLogo" style="max-height: 50px; max-width: 150px; margin-bottom: 8px; object-fit: contain;" alt="Logo" /><br>
        }
        <div class="store-name">@shopName</div>
        <div class="store-info">
            @shopAddress<br>
            ໂທ: @shopPhone
        </div>
    </div>

    <div class="divider-double"></div>

    <div class="order-meta">
        <table style="margin-bottom: 0;">
            <tr>
                <td>ເລກທີ: <strong>@Model.OrderNumber</strong></td>
                <td class="text-end">ວັນທີ: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
            </tr>
            <tr>
                <td>ພະນັກງານ: @(User.Identity?.Name ?? "Staff")</td>
                <td class="text-end">ປະເພດ: POS Sales</td>
            </tr>
        </table>
    </div>

    <table class="items-table">
        <tr class="items-header">
            <td style="width: 65%;">ລາຍການ</td>
            <td class="text-end" style="width: 35%;">ລວມ (ກີບ)</td>
        </tr>
        @foreach (var detail in Model.OrderDetails)
        {
            <tr>
                <td class="item-details">
                    <span class="fw-bold">@(detail.Part?.Name ?? detail.Service?.Name ?? "Item")</span><br>
                    <small>@detail.Quantity x @detail.UnitPrice.ToString("N0")</small>
                </td>
                <td class="text-end item-price">@((detail.Quantity * detail.UnitPrice).ToString("N0"))</td>
            </tr>
        }
    </table>

    <div class="divider"></div>

    <table class="summary-table">
        <tr class="summary-row">
            <td>ມູນຄ່າລວມສິນຄ້າ:</td>
            <td class="text-end">@Model.PartsCost.ToString("N0")</td>
        </tr>
        <tr class="summary-row">
            <td>ອາກອນ (Tax 10%):</td>
            <td class="text-end">@Model.TaxAmount.ToString("N0")</td>
        </tr>
        @if(Model.LaborCost > 0) {
        <tr class="summary-row">
            <td>ຄ່າແຮງຊ້ອມ:</td>
            <td class="text-end">@Model.LaborCost.ToString("N0")</td>
        </tr>
        }
        <tr class="total-row">
            <td>ຍອດລວມທັງໝົດ:</td>
            <td class="text-end">@Model.TotalAmount.ToString("N0") ₭</td>
        </tr>
    </table>

    <div class="footer text-center">
        <div style="white-space: pre-line; margin-bottom: 10px;">@receiptFooter</div>
        <div class="divider"></div>
        <div style="font-size: 8px; color: #666;">
            ພິມເມື່ອ: @DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss")<br>
            Powered by MotorShop System
        </div>
    </div>

    <script>
        // Automatic print trigger for desktop
        // window.onload = function() { window.print(); }
    </script>
</body>
</html>
