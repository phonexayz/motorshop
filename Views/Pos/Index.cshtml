@{
    ViewData["Title"] = "ຂາຍໜ້າຮ້ານ (POS)";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="bi bi-shop text-primary"></i> ລະບົບຂາຍໜ້າຮ້ານ (POS)</h1>
</div>

<div class="row">
    <!-- Left Column: Search & Products -->
    <div class="col-md-7 border-end">
        <div class="card shadow-sm border-0 mb-4 bg-light">
            <div class="card-body">
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-white"><i class="bi bi-upc-scan"></i></span>
                    <input type="text" id="partSearch" class="form-control" placeholder="ຍິງບາໂຄດ ຫຼື ຄົ້ນຫາຊື່ອາໄຫຼ່..." autofocus autocomplete="off">
                </div>
            </div>
        </div>

        <div class="row row-cols-1 row-cols-md-2 g-3" id="partsList" style="max-height: 65vh; overflow-y: auto;">
            @foreach (var part in ViewBag.Parts)
            {
                <div class="col part-item" data-id="@part.Id" data-name="@part.Name" data-price="@part.Price" data-barcode="@part.Barcode" data-stock="@part.StockQuantity">
                    <div class="card h-100 shadow-sm border-0 @(part.StockQuantity <= 0 ? "opacity-50" : "cursor-pointer btn-outline-primary")" onclick="addToCart(@part.Id)">
                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title fw-bold">@part.Name</h6>
                            <p class="card-text text-muted small mb-auto">ບາໂຄດ: @(part.Barcode ?? "-") | ຄົງເຫຼືອ: @part.StockQuantity @part.Unit</p>
                            <div class="mt-2 text-primary fw-bold fs-5 text-end">@part.Price.ToString("N0") ₭</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Right Column: Cart Panel -->
    <div class="col-md-5">
        <div class="card shadow h-100 border-0 d-flex flex-column">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-cart"></i> ກະຕ່າສິນຄ້າ</h5>
            </div>
            <div class="card-body p-0 flex-grow-1" style="max-height: 50vh; overflow-y: auto;">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th>ລາຍການ</th>
                            <th class="text-center" width="100px">ຈຳນວນ</th>
                            <th class="text-end" width="120px">ລວມ</th>
                            <th width="40px"></th>
                        </tr>
                    </thead>
                    <tbody id="cartBody">
                        <tr id="emptyCartRow">
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="bi bi-cart-x" style="font-size: 3rem;"></i><br>ຍັງບໍ່ມີລາຍການ
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="card-footer bg-light p-4 border-top">
                <div class="d-flex justify-content-between mb-2 text-muted">
                    <span>ລວມຈຳນວນຊິ້ນ:</span>
                    <span id="totalItems" class="fw-bold">0</span>
                </div>
                <div class="d-flex justify-content-between mb-1 text-muted">
                    <span>ຄ່າອາໄຫຼ່ (Subtotal):</span>
                    <span class="fw-bold"><span id="subtotalPrice">0</span> ₭</span>
                </div>
                <div class="d-flex justify-content-between mb-2 text-muted">
                    <span>ອາກອນ (Tax 10%):</span>
                    <span class="fw-bold text-danger">+ <span id="taxPrice">0</span> ₭</span>
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted">ປະເພດວຽກບໍລິການ (Quick Service):</label>
                    <select id="quickServiceSelect" class="form-select form-select-sm mb-2">
                        <option value="0">-- ເລືອກວຽກບໍລິການ --</option>
                    </select>
                    <label class="form-label small fw-bold text-muted">ຄ່າແຮງຊ້ອງ (Labor Cost):</label>
                    <div class="input-group input-group-sm">
                        <input type="number" id="laborCostInput" class="form-control text-end fw-bold" value="0" min="0" step="1000">
                        <span class="input-group-text">₭</span>
                    </div>
                </div>
                <div class="d-flex justify-content-between mb-4 mt-2 border-top pt-3">
                    <h4 class="mb-0">ຍອດລວມທັງໝົດ:</h4>
                    <h2 class="mb-0 text-primary fw-bold"><span id="totalPrice">0</span> ₭</h2>
                </div>
                <button type="button" class="btn btn-success btn-lg w-100 fw-bold py-3" id="btnCheckout" disabled>
                    <i class="bi bi-check-circle"></i> ຊຳລະເງິນ & ອອກບິນ
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let cart = [];

        // Load services for Quick Service dropdown
        document.addEventListener('DOMContentLoaded', function() {
            fetch('/Service/GetServicesJson')
                .then(response => response.json())
                .then(data => {
                    const select = document.getElementById('quickServiceSelect');
                    data.forEach(service => {
                        const option = document.createElement('option');
                        option.value = service.price;
                        option.textContent = service.name + ` (${service.price.toLocaleString()} ₭)`;
                        select.appendChild(option);
                    });
                });

            document.getElementById('quickServiceSelect').addEventListener('change', function() {
                if (this.value !== "0") {
                    document.getElementById('laborCostInput').value = this.value;
                    renderCart();
                }
            });
        });

        // Search and Barcode logic
        document.getElementById('partSearch').addEventListener('input', function(e) {
            const term = e.target.value.toLowerCase();
            const items = document.querySelectorAll('.part-item');
            
            // Check for exact barcode match first
            if (term.length >= 3) {
                const exactMatch = Array.from(items).find(item => item.dataset.barcode && item.dataset.barcode.toLowerCase() === term);
                if (exactMatch && e.inputType !== 'deleteContentBackward') {
                    addToCart(parseInt(exactMatch.dataset.id));
                    e.target.value = ''; // clear input after barcode scan
                    return;
                }
            }

            // Normal text filter
            items.forEach(item => {
                const name = item.dataset.name.toLowerCase();
                const barcode = (item.dataset.barcode || '').toLowerCase();
                if (name.includes(term) || barcode.includes(term)) {
                    item.style.display = 'block';
                } else {
                    item.style.display = 'none';
                }
            });
        });

        function addToCart(partId) {
            const partEl = document.querySelector(`.part-item[data-id="${partId}"]`);
            if (!partEl) return;
            
            const stock = parseInt(partEl.dataset.stock);
            if (stock <= 0) {
                Swal.fire({ icon: 'warning', title: 'ສິນຄ້າໝົດ', text: 'ອາໄຫຼ່ນີ້ບໍ່ມີໃນສະຕ໋ອກແລ້ວ' });
                return;
            }

            const existingItem = cart.find(i => i.partId === partId);
            if (existingItem) {
                if (existingItem.quantity >= stock) {
                    Swal.fire({ icon: 'error', title: 'ສະຕ໋ອກບໍ່ພໍ', toast: true, position: 'top-end', timer: 2000, showConfirmButton: false });
                    return;
                }
                existingItem.quantity++;
            } else {
                cart.push({
                    partId: partId,
                    name: partEl.dataset.name,
                    price: parseFloat(partEl.dataset.price),
                    quantity: 1,
                    stock: stock
                });
            }
            renderCart();
            
            // Flash effect on added item
            partEl.querySelector('.card').classList.add('bg-primary-subtle');
            setTimeout(() => partEl.querySelector('.card').classList.remove('bg-primary-subtle'), 200);
        }

        // Listen for Labor Cost changes
        document.getElementById('laborCostInput').addEventListener('input', function() {
            renderCart();
        });

        function updateQuantity(partId, delta) {
            const item = cart.find(i => i.partId === partId);
            if (!item) return;

            const newQty = item.quantity + delta;
            if (newQty <= 0) {
                removeFromCart(partId);
            } else if (newQty > item.stock) {
                Swal.fire({ icon: 'warning', title: 'ສະຕ໋ອກບໍ່ພໍ', text: `ມີສິນຄ້າພຽງ ${item.stock} ຊິ້ນເທົ່ານັ້ນ`, toast: true, position: 'top-end', timer: 2000, showConfirmButton: false });
            } else {
                item.quantity = newQty;
                renderCart();
            }
        }

        function removeFromCart(partId) {
            cart = cart.filter(i => i.partId !== partId);
            renderCart();
        }

        function renderCart() {
            const tbody = document.getElementById('cartBody');
            const emptyRow = document.getElementById('emptyCartRow');
            const totalItemsEl = document.getElementById('totalItems');
            const totalPriceEl = document.getElementById('totalPrice');
            const taxPriceEl = document.getElementById('taxPrice');
            const subtotalPriceEl = document.getElementById('subtotalPrice');
            const btnCheckout = document.getElementById('btnCheckout');

            if (cart.length === 0) {
                tbody.innerHTML = '';
                tbody.appendChild(emptyRow);
                emptyRow.style.display = '';
                totalItemsEl.textContent = '0';
                subtotalPriceEl.textContent = '0';
                taxPriceEl.textContent = '0';
                totalPriceEl.textContent = '0';
                btnCheckout.disabled = true;
                return;
            }

            emptyRow.style.display = 'none';
            tbody.innerHTML = '';
            
            let totalQty = 0;
            let subtotalAmt = 0;

            cart.forEach(item => {
                totalQty += item.quantity;
                subtotalAmt += item.quantity * item.price;

                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td><div class="fw-bold">${item.name}</div><div class="text-muted small">${item.price.toLocaleString()} ₭/ຊິ້ນ</div></td>
                    <td>
                        <div class="input-group input-group-sm">
                            <button class="btn btn-outline-secondary" onclick="updateQuantity(${item.partId}, -1)">-</button>
                            <input type="text" class="form-control text-center bg-white" value="${item.quantity}" readonly>
                            <button class="btn btn-outline-secondary" onclick="updateQuantity(${item.partId}, 1)">+</button>
                        </div>
                    </td>
                    <td class="text-end fw-bold text-dark pt-3">${(item.quantity * item.price).toLocaleString()} ₭</td>
                    <td class="text-center pt-3"><button class="btn btn-link text-danger p-0" onclick="removeFromCart(${item.partId})"><i class="bi bi-trash-fill"></i></button></td>
                `;
                tbody.appendChild(tr);
            });

            const taxAmt = subtotalAmt * 0.10;
            const laborAmt = parseFloat(document.getElementById('laborCostInput').value) || 0;
            const grandTotal = subtotalAmt + taxAmt + laborAmt;

            totalItemsEl.textContent = totalQty;
            subtotalPriceEl.textContent = subtotalAmt.toLocaleString();
            taxPriceEl.textContent = taxAmt.toLocaleString();
            totalPriceEl.textContent = grandTotal.toLocaleString();
            btnCheckout.disabled = false;
        }

        // Checkout Process
        document.getElementById('btnCheckout').addEventListener('click', async function() {
            if (cart.length === 0) return;

            const result = await Swal.fire({
                title: 'ຢືນຢັນການຊຳລະເງິນ?',
                html: `
                    <div class="text-start">
                        <div class="d-flex justify-content-between mb-1"><span>ຄ່າອາໄຫຼ່:</span> <strong>${document.getElementById('subtotalPrice').textContent} ₭</strong></div>
                        <div class="d-flex justify-content-between mb-1"><span>ອາກອນ (10%):</span> <strong>${document.getElementById('taxPrice').textContent} ₭</strong></div>
                        <div class="d-flex justify-content-between mb-1 text-success"><span>ຄ່າແຮງຊ້ອມ:</span> <strong>${(parseFloat(document.getElementById('laborCostInput').value) || 0).toLocaleString()} ₭</strong></div>
                        <hr>
                        <div class="d-flex justify-content-between fs-4"><span>ຍອດລວມ:</span> <strong class="text-primary">${document.getElementById('totalPrice').textContent} ₭</strong></div>
                    </div>
                `,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'ຢືນຢັນ',
                cancelButtonText: 'ຍົກເລີກ'
            });

            if (result.isConfirmed) {
                // Show loading
                Swal.fire({ title: 'ກຳລັງປະມວນຜົນ...', allowOutsideClick: false, didOpen: () => { Swal.showLoading() } });

                try {
                    const response = await fetch('/Pos/Checkout', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ 
                            items: cart.map(c => ({ partId: c.partId, quantity: c.quantity })),
                            laborCost: parseFloat(document.getElementById('laborCostInput').value) || 0
                        })
                    });
                    
                    const data = await response.json();
                    
                    if (data.success) {
                        await Swal.fire({ 
                            icon: 'success', 
                            title: 'ຊຳລະເງິນສຳເລັດ!', 
                            text: 'ທ່ານຕ້ອງການພິມບິນຮັບເງິນ ຫຼື ບໍ່?',
                            showCancelButton: true,
                            confirmButtonText: '<i class="bi bi-printer"></i> ພິມບິນ',
                            cancelButtonText: 'ປິດ',
                            confirmButtonColor: '#007bff'
                        }).then((printResult) => {
                            if (printResult.isConfirmed) {
                                window.open('/Pos/Receipt/' + data.orderId, '_blank');
                            }
                            // Clear cart and reload page to refresh stock
                            cart = [];
                            window.location.reload();
                        });
                    } else {
                        Swal.fire({ icon: 'error', title: 'ຜິດພາດ', text: data.message });
                    }
                } catch (err) {
                    Swal.fire({ icon: 'error', title: 'ຜິດພາດ', text: 'ເກີດຂໍ້ຜິດພາດໃນການເຊື່ອມຕໍ່ລະບົບ' });
                }
            }
        });
    </script>
}
