@model MotorcycleRepairShop.Models.Part
@{
    ViewData["Title"] = "ລາຍລະອຽດອາໄຫຼ່";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">ລາຍລະອຽດອາໄຫຼ່: @Model.Name</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <a asp-action="Logs" asp-route-partId="@Model.Id" class="btn btn-outline-primary">
                <i class="fas fa-history"></i> ປະຫວັດການເຄື່ອນໄຫວ
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="bi bi-pencil"></i> ແກ້ໄຂ
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> ກັບຄືນ
            </a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0">ຂໍ້ມູນທົ່ວໄປ</h5>
            </div>
            <div class="card-body">
                <table class="table table-borderless">
                    <tr>
                        <th width="30%">ລະຫັດອາໄຫຼ່</th>
                        <td>@(string.IsNullOrEmpty(Model.PartNumber) ? "-" : Model.PartNumber)</td>
                    </tr>
                    <tr>
                        <th>ບາໂຄ້ດ</th>
                        <td>
                            @if(!string.IsNullOrEmpty(Model.Barcode)) {
                                <span class="badge bg-dark">@Model.Barcode</span>
                            } else {
                                <span>-</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>ຊື່ອາໄຫຼ່</th>
                        <td class="fw-bold">@Model.Name</td>
                    </tr>
                    <tr>
                        <th>ລາຍລະອຽດ</th>
                        <td>@(string.IsNullOrEmpty(Model.Description) ? "-" : Model.Description)</td>
                    </tr>
                    <tr>
                        <th>ລຸ້ນທີ່ຮອງຮັບ</th>
                        <td>
                            @if(Model.CompatibleModels != null && Model.CompatibleModels.Any()) {
                                foreach(var m in Model.CompatibleModels) {
                                    <span class="badge bg-info text-dark me-1">@m</span>
                                }
                            } else {
                                <span class="text-muted">ໃຊ້ໄດ້ກັບຫຼາຍລຸ້ນ / ບໍ່ລະບຸ</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>ຜູ້ຜະລິດ/ຜູ້ຈັດຈຳໜ່າຍ</th>
                        <td>
                            @if (Model.Supplier != null) {
                                <a asp-controller="Supplier" asp-action="Details" asp-route-id="@Model.SupplierId">@Model.Supplier.Name</a>
                            } else {
                                @(string.IsNullOrEmpty(Model.LegacySupplierName) ? "-" : Model.LegacySupplierName)
                            }
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0">ຂໍ້ມູນລາຄາ ແລະ ສະຕັອກ</h5>
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <h6 class="text-muted">ສະຖານະສະຕັອກປະຈຸບັນ</h6>
                    <h2 class="@(Model.StockQuantity <= Model.MinStockLevel ? "text-danger" : "text-success") fw-bold">
                        @Model.StockQuantity <small class="fs-6">@Model.Unit</small>
                    </h2>
                    @if(Model.StockQuantity <= Model.MinStockLevel) {
                        <div class="alert alert-danger py-2 mt-2 mb-0">
                            <i class="bi bi-exclamation-triangle"></i> ສະຕັອກຕ່ຳກວ່າເກນ (@Model.MinStockLevel)
                        </div>
                    }
                </div>
                
                <table class="table table-sm">
                    <tr>
                        <th>ລາຄາຂາຍ:</th>
                        <td class="text-end text-primary fw-bold">@Model.Price.ToString("N0") ₭</td>
                    </tr>
                    <tr>
                        <th>ລາຄາຕົ້ນທຶນ:</th>
                        <td class="text-end">@(Model.Cost?.ToString("N0") ?? "-") @(Model.Cost.HasValue ? "₭" : "")</td>
                    </tr>
                    <tr>
                        <th>ກຳໄລເບື້ອງຕົ້ນ:</th>
                        <td class="text-end text-success">
                            @if(Model.Cost.HasValue) {
                                @((Model.Price - Model.Cost.Value).ToString("N0") + " ₭")
                            } else {
                                <span>-</span>
                            }
                        </td>
                    </tr>
                </table>
            </div>
            <div class="card-footer text-muted small text-center">
                ເພີ່ມເມື່ອ: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")<br />
                ອັບເດດລ່າສຸດ: @Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")
            </div>
        </div>
    </div>
</div>
