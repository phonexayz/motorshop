@model IEnumerable<MotorcycleRepairShop.Models.Part>
@{
    ViewData["Title"] = "แจ้งเตือนสต็อกต่ำ";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2 text-danger"><i class="bi bi-exclamation-triangle"></i> แจ้งเตือนสต็อกต่ำ</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> กลับไปคลังทั้งหมด
        </a>
    </div>
</div>

<div class="card border-danger shadow">
    <div class="card-header bg-danger text-white">
        <h5 class="mb-0">รายการสินค้าที่ต้องสั่งซื้อเพิ่ม (@Model.Count() รายการ)</h5>
    </div>
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>รหัส</th>
                            <th>ชื่ออะไหล่</th>
                            <th>ผู้จัดจำหน่าย</th>
                            <th class="text-end">จุดแจ้งเตือน</th>
                            <th class="text-end">สต็อกคงเหลือ</th>
                            <th class="text-center">ตรวจสอบ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var part in Model)
                        {
                            <tr>
                                <td>@part.PartNumber</td>
                                <td><strong>@part.Name</strong></td>
                                <td>
                                    @if (part.Supplier != null) {
                                        @part.Supplier.Name
                                    } else {
                                        @(string.IsNullOrEmpty(part.LegacySupplierName) ? "-" : part.LegacySupplierName)
                                    }
                                </td>
                                <td class="text-end text-muted">@part.MinStockLevel @part.Unit</td>
                                <td class="text-end">
                                    <span class="badge bg-danger fs-6">
                                        @part.StockQuantity @part.Unit
                                    </span>
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@part.Id" class="btn btn-sm btn-outline-primary">
                                        อัปเดตสต็อก
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-check-circle text-success fa-3x" style="font-size: 3rem;"></i>
                <h4 class="mt-3 text-muted">ไม่มีสินค้าสต็อกต่ำ</h4>
                <p>จำนวนสต็อกของสินค้าทั้งหมดอยู่ในเกณฑ์ปกติ</p>
            </div>
        }
    </div>
</div>
