@model List<MotorcycleRepairShop.Models.RepairOrder>
@{
    ViewData["Title"] = "ປະຫວັດການສ້ອມແປງ";
    var plateNumber = ViewBag.PlateNumber as string;
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold text-dark border-start border-primary border-5 ps-3">ປະຫວັດການສ້ອມແປງຕາມທະບຽນລົດ</h2>
            <p class="text-muted">ກວດສອບປະຫວັດການສ້ອມແປງທັງໝົດຂອງລົດແຕ່ລະຄັນ</p>
        </div>
    </div>

    <!-- Search Section -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius: 15px;">
        <div class="card-body p-4">
            <form asp-action="History" method="get" class="row g-3 align-items-end">
                <div class="col-md-6">
                    <label class="form-label fw-bold">ເລກທະບຽນລົດ</label>
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-primary"></i></span>
                        <input type="text" name="plateNumber" class="form-control border-start-0 ps-0" 
                               placeholder="ຕົວຢ່າງ: ກນ 1234" value="@plateNumber" required />
                    </div>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">
                        ຄົ້ນຫາປະຫວັດ
                    </button>
                </div>
                <div class="col-md-3">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg w-100">
                        ກັບຄືນ
                    </a>
                </div>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(plateNumber))
    {
        @if (Model != null && Model.Any())
        {
            <div class="alert alert-info border-0 shadow-sm mb-4 d-flex align-items-center" style="border-radius: 12px;">
                <i class="bi bi-info-circle-fill fs-4 me-3"></i>
                <div>
                    ພົບປະຫວັດການສ້ອມແປງທັງໝົດ <strong>@Model.Count</strong> ລາຍການ ສຳລັບທະບຽນ: <strong>@plateNumber</strong>
                </div>
            </div>

            <div class="row">
                @foreach (var order in Model)
                {
                    <div class="col-12 mb-4">
                        <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 15px;">
                            <div class="card-header bg-light d-flex justify-content-between align-items-center py-3 px-4">
                                <div>
                                    <span class="badge bg-primary me-2">@order.OrderNumber</span>
                                    <span class="text-muted small"><i class="bi bi-calendar-event me-1"></i> @order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                                <div>
                                    <span class="badge @(order.Status == "Completed" ? "bg-success" : "bg-warning") px-3">@order.Status</span>
                                    <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-link text-decoration-none ms-2">
                                        ເບິ່ງລາຍລະອຽດ <i class="bi bi-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                            <div class="card-body p-4">
                                <div class="row">
                                    <div class="col-md-4">
                                        <h6 class="fw-bold text-muted small text-uppercase mb-2">ຂໍ້ມູນລູກຄ້າ & ຊ່າງ</h6>
                                        <p class="mb-1"><strong>ລູກຄ້າ:</strong> @(order.Customer?.Name ?? "ລູກຄ້າທົ່ວໄປ")</p>
                                        <p class="mb-1"><strong>ຊ່າງສ້ອມ:</strong> @(order.Mechanic?.Name ?? "-")</p>
                                    </div>
                                    <div class="col-md-5">
                                        <h6 class="fw-bold text-muted small text-uppercase mb-2">ອາການເສຍ / ໝາຍເຫດ</h6>
                                        <p class="mb-0 text-dark">@order.ProblemDescription</p>
                                        @if (!string.IsNullOrEmpty(order.MechanicNotes))
                                        {
                                            <div class="mt-2 p-2 bg-light border-start border-3 border-info small">
                                                <strong>ໝາຍເຫດຊ່າງ:</strong> @order.MechanicNotes
                                            </div>
                                        }
                                    </div>
                                    <div class="col-md-3 text-end">
                                        <h6 class="fw-bold text-muted small text-uppercase mb-2">ຍອດລວມ</h6>
                                        <h4 class="fw-bold text-primary">@order.TotalAmount.ToString("N0") ₭</h4>
                                    </div>
                                </div>

                                <hr class="my-3 opacity-50">

                                <div class="row small">
                                    <div class="col-12">
                                        <strong>ລາຍການອາໄຫຼ່ ແລະ ບໍລິການ:</strong>
                                        <div class="d-flex flex-wrap gap-2 mt-2">
                                            @foreach (var detail in order.OrderDetails)
                                            {
                                                <span class="badge bg-light text-dark border p-2">
                                                    @(detail.Part?.Name ?? detail.Service?.Name ?? "ລາຍການ") x @detail.Quantity
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <div class="mb-3">
                    <i class="bi bi-search-heart display-1 text-muted opacity-25"></i>
                </div>
                <h4 class="text-secondary">ບໍ່ພົບປະຫວັດການສ້ອມແປງ</h4>
                <p class="text-muted">ບໍ່ພົບຂໍ້ມູນທະບຽນລົດ <strong>@plateNumber</strong> ໃນລະບົບ</p>
                <a asp-action="Create" class="btn btn-primary mt-3">ສ້າງໃບສັ່ງສ້ອມໃໝ່</a>
            </div>
        }
    }
</div>

<style>
    .card { transition: all 0.3s ease; }
    .card:hover { transform: translateY(-3px); }
    .input-group-text { border-color: #dee2e6; }
    .form-control:focus { box-shadow: none; border-color: #0d6efd; }
</style>
