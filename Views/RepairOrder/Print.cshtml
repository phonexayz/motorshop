@model MotorcycleRepairShop.Models.RepairOrder
@inject MotorcycleRepairShop.Services.ISettingService SettingService
@{
    Layout = null;
    var shopName = await SettingService.GetValueAsync("ShopName", "ຮ້ານສ້ອມແປງລົດຈັກ (MotorShop)");
    var shopAddress = await SettingService.GetValueAsync("ShopAddress", "123 ຖ.ສຸຂຸມວິທ ເມືອງວຽງຈັນ");
    var shopPhone = await SettingService.GetValueAsync("ShopPhone", "081-234-5678");
    var shopLogo = await SettingService.GetValueAsync("ShopLogo", "");
    var receiptFooter = await SettingService.GetValueAsync("ReceiptFooter", "-- ຂໍຂອບໃຈທີ່ໃຊ້ບໍລິການ --");
}

<!DOCTYPE html>
<html lang="lo">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ໃບແຈ້ງໜີ້ / ໃບເກັບເງິນ - @Model.OrderNumber</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+Lao:wght@400;700&display=swap');
        
        body {
            font-family: 'Noto Sans Lao', sans-serif !important;
            background-color: #f0f2f5;
            color: #333;
            -webkit-print-color-adjust: exact;
        }
        
        .invoice-box {
            max-width: 900px;
            margin: 30px auto;
            padding: 50px;
            background: #fff;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
            border-radius: 8px;
            position: relative;
        }
        
        .header-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 40px;
            border-bottom: 3px solid #f8f9fa;
            padding-bottom: 20px;
        }
        
        .logo-section img {
            max-height: 80px;
            max-width: 250px;
            object-fit: contain;
        }
        
        .shop-info-section {
            text-align: right;
        }
        
        .invoice-title {
            font-size: 28px;
            font-weight: 700;
            color: #1a202c;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }
        
        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 40px;
        }
        
        .info-card {
            padding: 20px;
            background: #f8fafc;
            border-radius: 6px;
            border-left: 4px solid #3182ce;
        }
        
        .info-card h6 {
            font-weight: 700;
            color: #4a5568;
            margin-bottom: 12px;
            text-transform: uppercase;
            font-size: 13px;
        }
        
        .table thead th {
            background-color: #f1f5f9;
            color: #475569;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 12px;
            border: none;
        }
        
        .table tbody td {
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
        }
        
        .summary-section {
            display: flex;
            justify-content: flex-end;
            margin-top: 30px;
        }
        
        .summary-table {
            width: 300px;
        }
        
        .summary-table td {
            padding: 8px 0;
        }
        
        .total-highlight {
            font-size: 20px;
            font-weight: 700;
            color: #2b6cb0;
        }
        
        .signature-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 100px;
            margin-top: 80px;
            text-align: center;
        }
        
        .sig-line {
            border-top: 1px solid #cbd5e0;
            padding-top: 10px;
            font-weight: 700;
        }
        
        .stamp-area {
            width: 100px;
            height: 100px;
            border: 2px dashed #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 10px;
            color: #cbd5e0;
            font-size: 10px;
            border-radius: 50%;
        }

        .no-print-bar {
            background: #2d3748;
            padding: 15px;
            position: sticky;
            top: 0;
            z-index: 1000;
            display: flex;
            justify-content: center;
            gap: 15px;
        }
        
        @@media print {
            body { background: #fff; padding: 0; }
            .invoice-box {
                box-shadow: none;
                margin: 0;
                width: 100%;
                max-width: 100%;
                padding: 20px;
            }
            .no-print-bar { display: none !important; }
        }
    </style>
</head>
<body>
    <div class="no-print-bar">
        <button onclick="window.print()" class="btn btn-primary d-flex align-items-center gap-2 px-4 shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                <path d="M2.5 8a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1"/>
                <path d="M5 1a2 2 0 0 0-2 2v2H2a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h1v1a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-1h1a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-1V3a2 2 0 0 0-2-2zM4 3a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2H4zm1 5a2 2 0 0 0-2 2v1H2a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v-1a2 2 0 0 0-2-2zm7 2v3a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1"/>
            </svg>
            <strong>ພິມໃບແຈ້ງໜີ້ (Print Invoice)</strong>
        </button>
        <button onclick="window.close()" class="btn btn-outline-light px-4">✖️ ປິດ (Close)</button>
    </div>

    <div class="invoice-box">
        <!-- Header -->
        <div class="header-row">
            <div class="logo-section">
                @if (!string.IsNullOrEmpty(shopLogo))
                {
                    <img src="@shopLogo" alt="Shop Logo" />
                }
                else
                {
                    <h3 class="fw-bold text-primary">@shopName</h3>
                }
            </div>
            <div class="shop-info-section">
                <div class="invoice-title text-primary">INVOICE</div>
                <div class="fw-bold mt-2">@shopName</div>
                <div class="text-muted small">
                    @shopAddress<br>
                    ໂທ: @shopPhone
                </div>
            </div>
        </div>

        <!-- Meta Info -->
        <div class="info-grid">
            <div class="info-card">
                <h6>ຂໍ້ມູນລູກຄ້າ / BILL TO</h6>
                <div class="fw-bold fs-5">@(Model.Customer?.Name ?? "Walk-in Guest")</div>
                <div class="small">
                    ໂທ: @(Model.Customer?.Phone ?? "-")<br>
                    ລົດ: @Model.Customer?.MotorcycleBrand @Model.Customer?.MotorcycleModel (@Model.MotorcycleLicensePlate)
                </div>
            </div>
            <div class="info-card" style="border-left-color: #2d3748;">
                <h6>ຂໍ້ມູນບິນ / DETAILS</h6>
                <div class="d-flex justify-content-between">
                    <span>ເລกທີບິນ (No.):</span>
                    <span class="fw-bold text-primary">@Model.OrderNumber</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span>ວັນທີ (Date):</span>
                    <span>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span>ຊ່າງສ້ອມ (Mechanic):</span>
                    <span>@(Model.Mechanic?.Name ?? "No Assigned")</span>
                </div>
            </div>
        </div>

        <!-- Problem Description -->
        <div class="mb-4">
            <h6 class="fw-bold text-muted small text-uppercase">ອາການເສຍ / PROBLEM DESCRIPTION</h6>
            <div class="p-3 bg-light rounded" style="border: 1px solid #edf2f7;">
                @Model.ProblemDescription
            </div>
        </div>

        <!-- Items Table -->
        <table class="table">
            <thead>
                <tr>
                    <th class="text-center" width="50">#</th>
                    <th>ລາຍການ (DESCRIPTION)</th>
                    <th class="text-center" width="100">ຈຳນວນ</th>
                    <th class="text-end" width="150">ລາຄາ/ໜ່ວຍ</th>
                    <th class="text-end" width="150">ລວມ (ກີບ)</th>
                </tr>
            </thead>
            <tbody>
                @{ int i = 1; }
                @foreach (var detail in Model.OrderDetails)
                {
                    <tr>
                        <td class="text-center text-muted">@i</td>
                        <td>
                            <div class="fw-bold">@(detail.Part?.Name ?? detail.Service?.Name ?? "Repair Service")</div>
                            @if (detail.Part != null && !string.IsNullOrEmpty(detail.Part.PartNumber))
                            {
                                <div class="small text-muted">PN: @detail.Part.PartNumber</div>
                            }
                        </td>
                        <td class="text-center">@detail.Quantity</td>
                        <td class="text-end">@detail.UnitPrice.ToString("N0")</td>
                        <td class="text-end fw-bold">@((detail.Quantity * detail.UnitPrice).ToString("N0"))</td>
                    </tr>
                    i++;
                }
            </tbody>
        </table>

        <!-- Summary -->
        <div class="summary-section">
            <table class="summary-table">
                <tr>
                    <td class="text-muted">ລວມຄ່າອາໄຫຼ່ (Parts Total):</td>
                    <td class="text-end fw-bold">@Model.PartsCost.ToString("N0")</td>
                </tr>
                <tr>
                    <td class="text-muted">ອາກອນ (Tax 10%):</td>
                    <td class="text-end text-danger fw-bold">+ @Model.TaxAmount.ToString("N0")</td>
                </tr>
                @if (Model.LaborCost > 0)
                {
                    <tr>
                        <td class="text-muted">ຄ່າແຮງຊ່າງ (Labor):</td>
                        <td class="text-end fw-bold">@Model.LaborCost.ToString("N0")</td>
                    </tr>
                }
                <tr>
                    <td colspan="2" style="border-top: 2px solid #2d3748; margin-top: 10px;"></td>
                </tr>
                <tr>
                    <td class="fw-bold text-primary">ຍອດລວມທັງໝົດ (TOTAL):</td>
                    <td class="text-end total-highlight">@Model.TotalAmount.ToString("N0") ₭</td>
                </tr>
            </table>
        </div>

        <!-- Notes -->
        @if (!string.IsNullOrEmpty(Model.MechanicNotes))
        {
            <div class="mt-4 p-3 border rounded border-primary bg-primary-subtle" style="--bs-bg-opacity: .05;">
                <h6 class="fw-bold text-primary small mb-1">ໝາຍເຫດຈາກຊ່າງ / MECHANIC NOTES:</h6>
                <div class="small">@Model.MechanicNotes</div>
            </div>
        }

        <!-- Signatures and Footer -->
        <div class="signature-section">
            <div>
                <div class="stamp-area">COMPANY STAMP</div>
                <div class="sig-line">ລາຍເຊັນລູກຄ້າ CUSTOMER SIGNATURE</div>
                <div class="small text-muted mt-1">(........................................................)</div>
            </div>
            <div>
                <div style="height: 110px;"></div>
                <div class="sig-line">ຜູ້ຮັບເງິນ / AUTHORIZED BY</div>
                <div class="small text-muted mt-1">(........................................................)</div>
            </div>
        </div>

        <div class="mt-5 pt-4 text-center border-top">
            <div class="fw-bold text-primary mb-1">@receiptFooter</div>
            <div class="small text-muted">ຂໍຂອບໃຈທີ່ໃຊ້ບໍລິການກັບ @shopName | THANK YOU FOR YOUR BUSINESS</div>
            <div class="small text-muted mt-4" style="font-size: 9px;">ພິມໂດຍລະບົບ MotorShop Management System - @DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss")</div>
        </div>
    </div>
</body>
</html>
