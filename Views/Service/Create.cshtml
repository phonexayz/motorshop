@model MotorcycleRepairShop.Models.Service
@{
    ViewData["Title"] = "ເພີ່ມບໍລິການໃໝ່";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="bi bi-plus-square"></i> ເພີ່ມຂໍ້ມູນບໍລິການ/ອັດຕາຄ່າແຮງ</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> ກັບໜ້າລາຍການ
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold">ຊື່ບໍລິການ/ລາຍການ <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="ເຊັ່ນ ປໍ້ຢາງ, ປ່ຽນຖ່າຍນ້ຳມັນເຄື່ອງ" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Category" class="form-label fw-bold">ໝວດໝູ່</label>
                            <input asp-for="Category" class="form-control" placeholder="ເຊັ່ນ ຢາງ, ເຄື່ອງยนต์, ລະບົບໄຟ" list="categoryOptions" />
                            <datalist id="categoryOptions">
                                <option value="ເຄື່ອງยนต์"></option>
                                <option value="ລໍ້ແລະຢາງ"></option>
                                <option value="ລະບົບໄຟ"></option>
                                <option value="ລະບົບເບຣກ"></option>
                                <option value="ທົ່ວໄປ"></option>
                            </datalist>
                            <span asp-validation-for="Category" class="text-danger"></span>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label asp-for="BasePrice" class="form-label fw-bold">ລາຄາຊ່າງ/ຄ່າບໍລິການມາດຕະຖານ (ກີບ) <span class="text-danger">*</span></label>
                            <input asp-for="BasePrice" type="number" step="0.01" class="form-control bg-light text-success fw-bold" required />
                            <span asp-validation-for="BasePrice" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EstimatedHours" class="form-label fw-bold">ໃຊ້ເວລາໂດຍປະມານ (ຊົ່ວໂມງ)</label>
                        <input asp-for="EstimatedHours" type="number" step="0.1" class="form-control" placeholder="ເຊັ່ນ 0.5 (ເຄິ່ງຊົ່ວໂມງ)" />
                        <small class="text-muted">ເວັ້ນວ່າງໄວ້ໄດ້ຫາກບໍ່ໄດ້ກຳນົດ</small>
                        <span asp-validation-for="EstimatedHours" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold">ລາຍລະອຽດເພີ່ມເຕີມ</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="ອະທິບາຍຂອບເຂດການເຮັດວຽກເພີ່ມເຕີມ..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <hr />
                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary px-5 fw-bold">
                            <i class="bi bi-save"></i> ບັນທຶກຂໍ້ມູນ
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
