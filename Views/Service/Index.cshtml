@model IEnumerable<MotorcycleRepairShop.Models.Service>
@{
    ViewData["Title"] = "ແຄັດຕາລັອກຄ່າບໍລິການມາດຕະຖານ";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="bi bi-tools"></i> ອັດຕາຄ່າບໍລິການ</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> ເພີ່ມບໍລິການໃໝ່
        </a>
    </div>
</div>

<div class="card mb-4 border-0 bg-transparent">
    <form asp-action="Index" method="get" class="row g-2">
        <div class="col-md-5">
            <input type="text" name="search" class="form-control" placeholder="ຄົ້ນຫາຊື່ບໍລິການ ຫຼື ໝວດໝູ່..." value="@ViewBag.Search">
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-dark w-100"><i class="bi bi-search"></i> ຄົ້ນຫາ</button>
        </div>
    </form>
</div>

<div class="row">
    @if (Model.Any())
    {
        var currentCategory = string.Empty;
        foreach (var item in Model)
        {
            var category = string.IsNullOrEmpty(item.Category) ? "ທົ່ວໄປ / ບໍ່ລະບຸໝວດໝູ່" : item.Category;
            
            @if (category != currentCategory)
            {
                <div class="col-12 mt-3 mb-2">
                    <h5 class="fw-bold text-primary border-bottom pb-2">@category</h5>
                </div>
                currentCategory = category;
            }

            <div class="col-md-6 col-lg-4 mb-3">
                <div class="card shadow-sm h-100 border-0 border-start border-4 border-primary">
                    <div class="card-body position-relative">
                        <div class="dropdown position-absolute top-0 end-0 mt-2 me-2">
                            <button class="btn btn-sm btn-light p-1" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-three-dots-vertical"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil me-2 text-warning"></i>ແກ້ໄຂ</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('ແນ່ໃຈຫລືບໍ່ທີ່ຈະລຶບບໍລິການນີ້?');">
                                        <button type="submit" class="dropdown-item text-danger"><i class="bi bi-trash me-2"></i>ລຶບອອກ</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                        
                        <h5 class="card-title fw-bold pe-4">@item.Name</h5>
                        <p class="card-text text-muted small mt-2 mb-3 align-top" style="min-height: 40px;">
                            @(string.IsNullOrEmpty(item.Description) ? "ບໍ່ມີລາຍລະອຽດ" : item.Description)
                        </p>
                        
                        <div class="d-flex justify-content-between align-items-end mt-auto">
                            <div>
                                <span class="d-block text-muted small"><i class="bi bi-clock"></i> ໃຊ້ເວລາປະມານ</span>
                                <span class="fw-bold">@(item.EstimatedHours.HasValue ? $"{item.EstimatedHours} ຊົ່ວໂມງ" : "-")</span>
                            </div>
                            <div class="text-end">
                                <span class="d-block text-muted small">ຄ່າແຮງ/ລາຄາມາດຕະຖານ</span>
                                <span class="fs-5 fw-bold text-success">@item.BasePrice.ToString("N0") ฿</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <i class="bi bi-tools text-muted mb-3 d-block" style="font-size: 3rem;"></i>
            <h4 class="text-muted">ບໍ່ພົບຂໍ້ມູນຄ່າບໍລິການ</h4>
            <p>ກະລຸນາກົດປຸ່ມ "ເພີ່ມບໍລິການໃໝ່" ເພື່ອສ້າງອັດຕາຄ່າແຮງຊ່າງ</p>
        </div>
    }
</div>
