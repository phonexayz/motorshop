@{
    ViewData["Title"] = "ເຂົ້າເຖິງຖືກປະຕິເສດ";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="card shadow border-0 mt-5">
            <div class="card-body p-5">
                <i class="bi bi-shield-lock text-danger" style="font-size: 5rem;"></i>
                <h2 class="mt-4 fw-bold text-dark">ບໍ່ມີສິດເຂົ້າເຖິງ!</h2>
                <p class="text-muted fs-5 mb-4">
                    ຂໍອະໄພ, ບັນຊີຂອງທ່ານບໍ່ມີສິດໃນການເຂົ້າເບິ່ງ ຫຼື ໃຊ້ງານໜ້ານີ້.<br />
                    ກະລຸນາຕິດຕໍ່ຜູ້ເບິ່ງແຍງລະບົບ (Admin) ຫຼື ຜູ້ຈັດການຮ້ານ.
                </p>
                <a href="/" class="btn btn-primary px-4 py-2">
                    <i class="bi bi-house-door me-2"></i> ກັບຄືນໜ້າຫຼັກ
                </a>
            </div>
        </div>
    </div>
</div>
